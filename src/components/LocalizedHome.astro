---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTourApiImage } from '../data/tourApiImages.js';

const { content } = Astro.props;
const heroImage = getTourApiImage('gyeongju', {
  src: '/images/domestic-season-guide.svg',
  alt: '',
  caption: ''
});

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Tourpick360',
  url: 'https://tourpick360.com',
  description: content.description,
  inLanguage: content.lang
};
---
<BaseLayout title={content.title} description={content.description} lang={content.lang}>
  <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

  <section class="home-hero localized-home">
    <div class="home-hero-copy">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>{content.heading}</h1>
      <p>{content.intro}</p>
      <div class="hero-actions">
        <a class="button primary" href="/domestic/">{content.primaryCta}</a>
        <a class="button" href="/domestic/jeju/">{content.secondaryCta}</a>
      </div>
    </div>
    <div class="home-radar" aria-label="Tourpick360">
      <figure class="home-atlas" aria-hidden="true">
        <img src={heroImage.src} alt="" loading="eager" />
      </figure>
      {content.stats.map(([label, value]) => (
        <div>
          <span>{label}</span>
          <strong>{value}</strong>
        </div>
      ))}
    </div>
  </section>

  <section class="festival-hub">
    <div class="section-heading">
      <p class="eyebrow">{content.sections[0].eyebrow}</p>
      <h2>{content.sections[0].heading}</h2>
      <p class="muted">{content.sections[0].body}</p>
    </div>
    <div class="festival-grid">
      {content.cards.map(([title, region, body]) => (
        <article class="festival-card">
          <span>{region}</span>
          <h3>{title}</h3>
          <p>{body}</p>
          <a class="card-link" href="/domestic/festivals/">Tourpick360</a>
        </article>
      ))}
    </div>
  </section>

  <section class="content-roadmap">
    <div class="section-heading">
      <p class="eyebrow">{content.sections[1].eyebrow}</p>
      <h2>{content.sections[1].heading}</h2>
      <p class="muted">{content.sections[1].body}</p>
    </div>
    <div class="roadmap-list">
      {content.guides.map(([title, body], index) => (
        <article>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
