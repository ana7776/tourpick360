    const tabs = document.querySelectorAll('.tool-tab');
    const basicList = document.querySelector('#basic-list');
    const improvedList = document.querySelector('#improved-list');
    const reasonText = document.querySelector('#reason-text');
    const impactList = document.querySelector('#impact-list');
    const checkList = document.querySelector('#check-list');
    const relatedLink = document.querySelector('#related-link');
    const relatedLinkList = document.querySelector('#related-link-list');

    function renderList(list, items) {
      list.replaceChildren();
      items.forEach((text) => {
        const li = document.createElement('li');
        li.textContent = text;
        list.appendChild(li);
      });
    }

    function render(mode) {
      const item = data[mode];
      if (!item) return;
      renderList(basicList, item.basic);
      renderList(improvedList, item.improved);
      reasonText.textContent = item.reason;
      renderList(impactList, item.impact);
      renderList(checkList, item.checks);
      relatedLink.href = item.href;
      relatedLink.textContent = item.href.includes('problems') ? '문제 해결 글 보기' : '관련 가이드 보기';
      relatedLinkList.replaceChildren();
      (relatedLinksByMode[mode] || []).forEach((link) => {
        const li = document.createElement('li');
        const anchor = document.createElement('a');
        anchor.href = link.href;
        anchor.textContent = `${link.label}: ${link.title}`;
        li.appendChild(anchor);
        relatedLinkList.appendChild(li);
      });
      tabs.forEach((tab) => tab.classList.toggle('active', tab.dataset.mode === mode));
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => render(tab.dataset.mode));
    });

    render('family');
  </script>
</BaseLayout>
