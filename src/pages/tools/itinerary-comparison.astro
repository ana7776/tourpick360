---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="기본 vs 개선 여행 일정 비교 도구 - Tourpick360" description="여행 유형을 선택하면 무리한 기본 일정과 더 안정적인 개선 일정을 비교하고, 왜 개선안이 나은지 확인할 수 있는 Tourpick360 도구입니다.">
  <section class="tool-page">
    <div class="section-heading">
      <p class="eyebrow">Comparison Tool</p>
      <h1>기본 vs 개선 여행 일정 비교 도구</h1>
      <p class="muted">여행 유형을 선택하면 자주 실패하는 기본 일정과 실제로 더 안정적인 개선 일정을 비교합니다. 각 결과에는 추천 이유와 확인할 체크포인트를 함께 제공합니다.</p>
    </div>

    <div class="tool-controls" aria-label="여행 유형 선택">
      <button type="button" class="tool-tab active" data-mode="family">가족여행</button>
      <button type="button" class="tool-tab" data-mode="couple">커플여행</button>
      <button type="button" class="tool-tab" data-mode="parents">부모님 여행</button>
      <button type="button" class="tool-tab" data-mode="rain">비 오는 날</button>
      <button type="button" class="tool-tab" data-mode="festival">축제 여행</button>
      <button type="button" class="tool-tab" data-mode="budget">예산 절약</button>
      <button type="button" class="tool-tab" data-mode="noCar">차 없는 여행</button>
      <button type="button" class="tool-tab" data-mode="lateArrival">늦은 도착</button>
      <button type="button" class="tool-tab" data-mode="parking">주차 만차</button>
      <button type="button" class="tool-tab" data-mode="jejuReturn">제주 반납일</button>
    </div>

    <div class="comparison-grid">
      <article>
        <p class="eyebrow">Basic</p>
        <h2 id="basic-title">기본 일정</h2>
        <ul id="basic-list"></ul>
      </article>
      <article>
        <p class="eyebrow">Improved</p>
        <h2 id="improved-title">개선 일정</h2>
        <ul id="improved-list"></ul>
      </article>
    </div>

    <section class="reason-box">
      <h2>추천 이유</h2>
      <p id="reason-text"></p>
      <div class="reason-detail-grid" aria-label="개선 효과와 점검 기준">
        <article>
          <h3>개선 효과</h3>
          <ul id="impact-list"></ul>
        </article>
        <article>
          <h3>확인 포인트</h3>
          <ul id="check-list"></ul>
        </article>
      </div>
      <p><a id="related-link" href="/travel-tips/">관련 글 보기</a></p>
      <ul id="related-link-list"></ul>
    </section>
  </section>

