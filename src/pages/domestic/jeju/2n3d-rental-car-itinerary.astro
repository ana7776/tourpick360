---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ApprovalArticle from '../../../components/ApprovalArticle.astro';
import { allJejuArticles } from '../../../data/jejuApprovalArticles.js';

const article = {
  slug: '2n3d-rental-car-itinerary',
  title: '제주 2박 3일 렌터카 동선 기본안',
  description: '처음 제주를 방문하는 여행자를 위해 2박 3일 렌터카 동선을 숙소 위치, 이동 피로, 날씨 변수 기준으로 정리합니다.',
  category: '제주 코스',
  target: '첫 제주 여행자, 렌터카 여행자, 짧은 일정 여행자',
  budget: '숙소 이동 횟수와 렌터카 시간을 함께 고려',
  area: '공항권, 서쪽, 중문, 동부',
  caution: '제주 전체를 한 번에 돌려고 하면 이동 시간이 여행 만족도를 낮출 수 있습니다.',
  intro: '처음 제주를 방문한다면 섬 전체를 한 번에 돌기보다 숙소 위치를 기준으로 하루 이동 범위를 줄이는 편이 좋습니다. 2박 3일 일정은 생각보다 짧기 때문에 관광지 개수를 늘리는 것보다 이동 피로를 관리하는 것이 중요합니다.',
  sections: [
    {
      heading: '1일 차는 도착 피로를 줄이는 날',
      body: '첫날은 항공편 시간과 렌터카 인수 시간을 기준으로 일정을 짜야 합니다. 오후나 저녁 도착이라면 공항권이나 애월처럼 접근이 쉬운 지역을 선택하는 것이 좋습니다. 첫날부터 성산이나 중문까지 길게 이동하면 다음 날 컨디션에 영향을 줄 수 있습니다.'
    },
    {
      heading: '2일 차는 한 권역을 깊게 보는 날',
      body: '둘째 날은 제주 여행의 중심이 되는 날입니다. 서쪽, 남쪽, 동쪽 중 한 권역을 정하고 숙소와 가까운 관광지를 묶는 방식이 효율적입니다. 예를 들어 중문 숙소라면 서귀포와 남부 관광지를, 성산 숙소라면 우도와 동부 해안을 함께 보는 식입니다.'
    },
    {
      heading: '3일 차는 공항 복귀를 먼저 계산',
      body: '마지막 날은 관광지보다 항공편 시간을 먼저 기준으로 잡아야 합니다. 오전 항공편이라면 공항 근처에서 숙박하거나 전날 밤 제주시로 이동하는 것이 안전합니다. 오후 항공편이라면 공항으로 돌아오는 길에 가까운 관광지 하나 정도만 넣는 편이 좋습니다.'
    },
    {
      heading: '비 오는 날 대체 동선',
      body: '렌터카 여행은 날씨에 따라 동선을 바꾸기 쉽다는 장점이 있습니다. 비가 강한 날에는 오름과 해안 절벽 코스를 줄이고, 실내 관광지와 식당, 카페를 한 권역 안에서 묶는 것이 좋습니다. 숙소 주변 대체 코스를 미리 정해두면 일정이 무너지지 않습니다.'
    }
  ],
  checklist: ['항공편 도착과 출발 시간', '렌터카 인수와 반납 위치', '하루 이동 거리', '숙소 체크인 시간', '비 오는 날 대체 코스'],
  faqs: [
    ['제주 2박 3일에 동서남북을 모두 볼 수 있나요?', '가능은 하지만 이동 시간이 길어져 피로가 커질 수 있습니다. 처음이라면 2개 권역 정도로 줄이는 편이 만족도가 높습니다.'],
    ['숙소를 매일 옮기는 것이 좋나요?', '동선은 줄일 수 있지만 짐 이동과 체크인 시간이 늘어납니다. 가족 여행이라면 한 곳 또는 최대 두 곳을 추천합니다.'],
    ['렌터카 없이 2박 3일 제주 여행이 가능한가요?', '가능하지만 이동 범위를 줄여야 합니다. 공항권, 제주시, 중문처럼 대중교통과 택시 접근성이 있는 지역을 중심으로 잡는 편이 좋습니다.']
  ]
};

const related = allJejuArticles.filter((item) => item.title !== article.title).slice(0, 4);
---
<BaseLayout title={`${article.title} - Tourpick360`} description={article.description}>
  <ApprovalArticle article={article} related={related} />
</BaseLayout>
