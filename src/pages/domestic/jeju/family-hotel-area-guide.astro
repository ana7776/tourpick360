---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ApprovalArticle from '../../../components/ApprovalArticle.astro';
import { allJejuArticles } from '../../../data/jejuApprovalArticles.js';

const article = {
  slug: 'family-hotel-area-guide',
  title: '제주 가족여행 숙소 지역별 선택 기준',
  description: '제주 가족여행 숙소를 공항권, 애월, 중문, 성산 지역별로 비교하고 이동 피로, 식사 접근성, 날씨 대응 기준으로 정리합니다.',
  category: '제주 숙소',
  target: '아이 동반 가족, 3대 가족, 첫 제주 여행자',
  budget: '숙소 시설보다 이동 피로와 식사 접근성까지 포함해 판단',
  area: '공항권, 애월, 중문, 성산',
  caution: '사진과 가격만 보고 예약하면 하루 이동 시간이 길어질 수 있습니다.',
  intro: '아이와 함께 제주를 여행한다면 숙소의 시설보다 먼저 봐야 할 것은 이동 거리와 식사 편의성입니다. 제주 숙소는 지역별 성격이 뚜렷해서 같은 가격이라도 여행 만족도가 크게 달라집니다. Tourpick360은 공항권, 애월, 중문, 성산을 가족 여행자의 실제 피로도 기준으로 비교합니다.',
  sections: [
    {
      heading: '공항권 숙소가 맞는 가족',
      body: '공항권은 늦은 도착, 이른 출발, 짧은 1박 일정에 유리합니다. 렌터카 인수와 반납 시간이 줄고, 주변 식당과 편의시설을 찾기 쉽습니다. 다만 숙소에서 휴양을 즐기기보다는 이동 전후의 피로를 줄이는 용도로 접근하는 편이 좋습니다.'
    },
    {
      heading: '애월 숙소가 맞는 가족',
      body: '애월은 서쪽 해안 분위기와 카페, 바다 산책을 함께 즐기기 좋은 지역입니다. 공항 접근성도 나쁘지 않아 첫날 일정으로 배치하기 쉽습니다. 하지만 해안도로 정체와 인기 식당 대기 시간이 생길 수 있어 아이와 함께라면 식사 시간대를 미리 조정해야 합니다.'
    },
    {
      heading: '중문 숙소가 맞는 가족',
      body: '중문은 리조트 시설과 실내 대체 일정이 필요한 가족에게 강점이 있습니다. 수영장, 조식, 산책로, 키즈 시설을 활용하기 좋고 비가 와도 일정을 크게 바꾸지 않아도 됩니다. 다만 숙소에 머무는 시간이 적다면 비용 대비 만족도가 낮을 수 있습니다.'
    },
    {
      heading: '성산 숙소가 맞는 가족',
      body: '성산은 동부 관광지와 우도, 일출 일정을 계획하는 가족에게 적합합니다. 아침 일찍 움직여야 하는 일정에서 숙소 위치의 장점이 큽니다. 반대로 마지막 날 공항 복귀가 빠르다면 이동 시간이 부담이 될 수 있어 숙박 날짜를 신중히 골라야 합니다.'
    }
  ],
  checklist: ['하루 평균 차량 이동 시간', '아침 식사 가능 여부', '무료 주차와 엘리베이터', '비 오는 날 숙소 안 대체 활동', '아이 침대 구성과 욕실 구조'],
  faqs: [
    ['가족여행 숙소는 한 지역에만 잡아도 되나요?', '2박 3일이라면 한 지역에 머물러도 괜찮지만, 동서 이동이 많다면 2개 권역으로 나누는 방식이 피로를 줄일 수 있습니다.'],
    ['아이와 함께라면 중문이 가장 좋은가요?', '리조트 시설을 활용한다면 중문이 좋습니다. 하지만 짧은 일정이나 늦은 도착 일정이라면 공항권이 더 편할 수 있습니다.'],
    ['가성비 가족 숙소는 어떤 기준으로 봐야 하나요?', '최저가보다 주차, 식사 접근성, 객실 크기, 이동 시간을 함께 봐야 실제 가성비를 판단할 수 있습니다.']
  ]
};

const related = allJejuArticles.filter((item) => item.title !== article.title).slice(0, 4);
---
<BaseLayout title={`${article.title} - Tourpick360`} description={article.description}>
  <ApprovalArticle article={article} related={related} />
</BaseLayout>
