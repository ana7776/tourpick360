---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { allFestivalArticles, festivalApprovalArticles } from '../../../data/festivalApprovalArticles.js';
import { getTourApiImage } from '../../../data/tourApiImages.js';

const heroImage = getTourApiImage('festival_spring', getTourApiImage('festival_summer', {
  src: '/images/domestic-season-guide.svg',
  alt: '국내 축제 여행 계절별 가이드 이미지',
  caption: '계절, 지역, 동행 유형을 함께 보는 축제 여행 선택 기준'
}));

const seasonGroups = [
  {
    season: '봄',
    months: '3월 - 5월',
    body: '봄꽃, 걷기 여행, 가족 동반 축제',
    href: '/domestic/festivals/spring-flower-festival-hotel-area/',
    regions: ['제주', '경주', '여수', '강릉']
  },
  {
    season: '여름',
    months: '6월 - 8월',
    body: '바다, 야간 공연, 성수기 숙소',
    href: '/domestic/festivals/summer-beach-festival-checklist/',
    regions: ['부산', '강릉', '제주', '속초']
  },
  {
    season: '가을',
    months: '9월 - 11월',
    body: '미식, 산책, 지역 축제',
    href: '/domestic/festivals/autumn-food-festival-route/',
    regions: ['전주', '여수', '경주', '부산']
  },
  {
    season: '겨울',
    months: '12월 - 2월',
    body: '빛 축제, 실내 대체 코스, 방한',
    href: '/domestic/festivals/winter-light-festival-hotel-area/',
    regions: ['강릉', '부산', '서울', '제주']
  }
];

const decisionRows = [
  {
    name: '숙소 위치',
    summary: '행사장 거리보다 복귀 동선, 식사 접근성, 체크인 시간을 같이 봅니다.',
    href: '/domestic/festivals/festival-hotel-booking-checklist/'
  },
  {
    name: '날씨 변수',
    summary: '야외 체류가 긴 축제는 비 예보와 실내 대체 코스를 미리 묶어둡니다.',
    href: '/domestic/festivals/rainy-season-festival-travel-plan/'
  },
  {
    name: '예산 관리',
    summary: '숙소와 교통 고정비 외에 현장 먹거리, 주차, 택시비를 따로 계산합니다.',
    href: '/domestic/festivals/festival-travel-budget-plan/'
  },
  {
    name: '더위와 야간 행사',
    summary: '초여름 축제는 낮 휴식과 저녁 복귀 동선을 먼저 비워두면 피로가 줄어듭니다.',
    href: '/domestic/festivals/early-summer-night-festival-heat-plan/'
  }
];

const travelerGuides = [
  ['가족 여행', '아이 식사 시간, 낮 휴식, 야간 행사 개수를 먼저 줄여야 일정이 안정됩니다.'],
  ['커플 여행', '사진 명소보다 저녁 복귀 동선과 숙소 분위기를 함께 보는 편이 좋습니다.'],
  ['부모님 동반', '도보 거리, 경사, 셔틀, 화장실 위치처럼 현장 이동 난이도를 우선합니다.'],
  ['비 오는 날', '실내 전시, 카페, 숙소 주변 식사를 묶어 축제장 체류 시간을 조정합니다.']
];

const bookingSteps = [
  ['1단계', '공식 축제 기간과 운영 시간을 확인합니다.'],
  ['2단계', '숙소 권역을 행사장, 역, 식사 동선 기준으로 2곳 이상 비교합니다.'],
  ['3단계', '주차장, 셔틀, 택시 대기, 대중교통 막차를 확인합니다.'],
  ['4단계', '비 예보와 행사 변경 가능성을 보고 취소 조건을 기록합니다.']
];

const featuredArticles = festivalApprovalArticles.slice(0, 4);
---
<BaseLayout title="국내 축제 여행 가이드 - Tourpick360" description="국내 계절 축제 여행에서 숙소 위치, 주차, 이동 동선, 예산, 가족 동반 기준을 정리한 Tourpick360 축제 여행 허브입니다.">
  <section class="domestic-hero">
    <div>
      <p class="eyebrow">Festival Travel 360</p>
      <h1>국내 축제 여행을 계절과 동선 기준으로 고르기</h1>
      <p>
        축제 여행은 행사 이름만 보고 정하면 숙소, 주차, 식사, 복귀 동선에서 피로가 커질 수 있습니다.
        Tourpick360은 계절별 축제 여행을 실제 예약 전에 확인해야 할 기준으로 정리합니다.
      </p>
    </div>
    <figure class="domestic-visual">
      <img src={heroImage.src} alt={heroImage.alt} width="960" height="540" />
      <figcaption>{heroImage.caption}</figcaption>
    </figure>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Local Festival Guide</p>
      <h2>지역 축제 방문 가이드</h2>
      <p class="muted">직접 다녀온 축제와 현장 안내 기준을 함께 정리해 방문 전 동선, 사진 포인트, 체류 시간을 판단할 수 있게 만든 글입니다.</p>
    </div>
    <div class="article-photo-grid">
      <figure>
        <a href="/domestic/festivals/gokseong-rose-festival-guide/">
          <img src="/images/gokseong-rose-festival/rose-tunnel.jpg" alt="곡성 세계장미축제 장미터널" width="1920" height="1081" loading="lazy" />
        </a>
        <figcaption>
          <a href="/domestic/festivals/gokseong-rose-festival-guide/">곡성 세계장미축제 정보성 글 보기</a>
        </figcaption>
      </figure>
      <figure>
        <a href="/domestic/festivals/gokseong-rose-festival-guide/">
          <img src="/images/gokseong-rose-festival/rose-garden-close.jpg" alt="곡성 세계장미축제 장미 정원" width="1600" height="901" loading="lazy" />
        </a>
        <figcaption>방문 전 기간, 장소, 추천 동선, 사진 포인트를 함께 확인하세요.</figcaption>
      </figure>
      <figure>
        <a href="/domestic/festivals/imsil-n-rose-festival-guide/">
          <img src="/images/imsil-n-rose-festival/rose-tunnel.jpg" alt="임실N장미축제 장미터널과 방문객 포토존" width="4000" height="2252" loading="lazy" />
        </a>
        <figcaption>
          <a href="/domestic/festivals/imsil-n-rose-festival-guide/">임실N장미축제 5월 29일 방문기 보기</a>
        </figcaption>
      </figure>
      <figure>
        <a href="/domestic/festivals/imsil-n-rose-festival-guide/">
          <img src="/images/imsil-n-rose-festival/night-rose-garden.jpg" alt="임실N장미축제 야간 조명 정원과 공연장" width="1440" height="811" loading="lazy" />
        </a>
        <figcaption>장미정원, 메인무대, 야간 조명 산책까지 직접 다녀온 동선으로 정리했습니다.</figcaption>
      </figure>
    </div>
  </section>

  <section class="domestic-board">
    <div class="board-intro">
      <p class="eyebrow">Festival Decision</p>
      <h2>예약 전에 먼저 볼 기준</h2>
      <p>축제 여행은 날짜를 먼저 정하면 숙소와 이동 선택지가 좁아집니다. 행사장과 가까운지만 보지 말고 하루가 끝나는 지점까지 같이 비교합니다.</p>
    </div>
    <div class="region-board">
      {decisionRows.map((row, index) => (
        <a class="region-row" href={row.href}>
          <span class="region-number">{String(index + 1).padStart(2, '0')}</span>
          <div>
            <h3>{row.name}</h3>
            <p>{row.summary}</p>
          </div>
          <dl>
            <div>
              <dt>핵심</dt>
              <dd>예약 전 확인</dd>
            </div>
            <div>
              <dt>목적</dt>
              <dd>피로도 줄이기</dd>
            </div>
          </dl>
        </a>
      ))}
    </div>
  </section>

  <section class="season-lane">
    <div class="section-heading">
      <p class="eyebrow">Season Guide</p>
      <h2>계절별 축제 여행 준비 포인트</h2>
    </div>
    <div class="season-track">
      {seasonGroups.map((item) => (
        <article>
          <span>{item.months}</span>
          <h3><a href={item.href}>{item.season}</a></h3>
          <p>{item.body}</p>
          <div class="season-regions">
            {item.regions.map((region) => <strong>{region}</strong>)}
          </div>
          <small>숙소 위치, 주차, 이동 동선, 대체 코스를 함께 확인합니다.</small>
        </article>
      ))}
    </div>
  </section>

  <section class="domestic-routes">
    <div>
      <p class="eyebrow">Traveler Type</p>
      <h2>동행 유형별로 달라지는 축제 여행 기준</h2>
      <p>같은 축제라도 가족, 커플, 부모님 동반 여행에서는 좋은 숙소와 코스가 달라집니다. 이동 피로와 저녁 복귀 방식을 먼저 정하면 선택이 쉬워집니다.</p>
    </div>
    <div class="route-notes">
      {travelerGuides.map(([title, body]) => (
        <section>
          <h3>{title}</h3>
          <p>{body}</p>
        </section>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Featured Guides</p>
      <h2>계절별 대표 축제 여행 글</h2>
      <p class="muted">봄, 여름, 가을, 겨울 축제 여행에서 먼저 확인하기 좋은 글입니다.</p>
    </div>
    <div class="article-grid">
      {featuredArticles.map((item) => (
        <article class="article-card">
          <p>{item.season}</p>
          <h3><a href={`/domestic/festivals/${item.slug}/`}>{item.title}</a></h3>
          <span>{item.description}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Festival Articles</p>
      <h2>축제 여행 준비 글</h2>
      <p class="muted">실제 예약과 방문 전에 확인하면 좋은 숙소, 주차, 이동, 예산 정보를 우선 정리합니다.</p>
    </div>
    <div class="article-grid">
      {allFestivalArticles.map((item) => (
        <article class="article-card">
          <p>{item.category}</p>
          <h3><a href={item.href}>{item.title}</a></h3>
          <span>{item.description}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="checklist-roadmap">
    <p class="eyebrow">Booking Flow</p>
    <h2>축제 여행 예약 전 확인 순서</h2>
    <ol>
      {bookingSteps.map(([step, body]) => (
        <li><strong>{step}</strong><span>{body}</span></li>
      ))}
    </ol>
  </section>
</BaseLayout>
