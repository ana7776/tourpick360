    bestFor: '오목대, 한벽터널, 한옥마을 북동쪽을 짧게 볼 때',
    caution: '오목대에서 한벽터널로 이어지는 도로변이라 진입 방향과 남은 자리를 함께 봐야 합니다.'
  },
  {
    name: '남부시장 천변주차장',
    spaces: '260면',
    address: '전동 331',
    fee: '기본 30분 무료, 추가 10분 200원, 1일 최대 5,000원',
    bestFor: '남부시장 식사, 야시장, 풍남문 동선을 함께 넣을 때',
    caution: '시장 이용 쿠폰 조건이 있을 수 있어 현장 안내를 확인하는 편이 좋습니다.'
  },
  {
    name: '남부시장 남부주차장',
    spaces: '75면',
    address: '전동 187-14',
    fee: '기본 10분 200원, 추가 10분 200원, 1일 최대 6,000원',
    bestFor: '남부시장에 먼저 들렀다가 한옥마을로 걸어갈 때',
    caution: '면수가 적어 식사 피크 시간에는 천변주차장도 함께 봐야 합니다.'
  },
  {
    name: '풍남문상점가고객주차장',
    spaces: '상점가 고객 주차',
    address: '풍남문2길 60',
    fee: '기본 10분 200원, 추가 10분 200원, 1일 최대 6,000원',
    bestFor: '풍남문, 남부시장, 전동성당을 먼저 보고 한옥마을로 들어갈 때',
    caution: '상점가 이용 동선과 맞을 때 편합니다. 한옥마을 중심부만 보는 일정이면 걷는 거리를 계산해야 합니다.'
  },
  {
    name: '국립무형유산원',
    spaces: '305면',
    address: '서학로 95',
    fee: '무료',
    bestFor: '무형유산원, 남천교, 전주천 산책을 함께 넣을 때',
    caution: '한옥마을 중심부까지는 걸어야 하므로 부모님 동반이면 동선을 짧게 잡습니다.'
  },
  {
    name: '한국전통문화전당',
    spaces: '144면',
    address: '현무1길 20',
    fee: '24시간 연중무휴, 전당 방문객 중심 이용',
    bestFor: '전당 방문이나 객리단길 쪽 일정을 함께 잡을 때',
    caution: '전당 방문 외 주차가 제한될 수 있어 단순 한옥마을 주차 대안으로만 보기에는 변수가 있습니다.'
  }
];

const parkingMapRows = parkingChoices.map((parking) => ({
  ...parking,
  mapUrl: naverMapSearchUrl({
    region: '전주 한옥마을',
    name: parking.name,
    address: parking.address
  })
}));

const naverMapNcpKeyId = import.meta.env.PUBLIC_NAVER_MAP_NCP_KEY_ID;
const parkingMapData = parkingMapRows.map((parking) => ({
  name: parking.name,
  address: parking.address,
  searchAddress: parking.address.includes('~') ? `${parking.name} 전주 한옥마을` : `전주시 ${parking.address}`,
  mapUrl: parking.mapUrl
}));

const parkingStrategies = [
  ['평일 오전 방문', '제1·2공영주차장을 먼저 확인해도 무난합니다. 짧은 관람이라면 이동 거리를 줄이는 쪽이 편합니다.'],
  ['주말 오후 방문', '제1·2공영주차장 진입 대기보다 제4공영주차장과 셔틀을 먼저 고려하는 편이 스트레스가 적습니다.'],
  ['남부시장 식사 포함', '남부시장 천변주차장이나 남부주차장을 기준점으로 잡고 풍남문, 전동성당, 경기전 순서로 걷습니다.'],
  ['부모님 동반', '가까운 주차장에 실패하면 무리해서 골목을 돌기보다 제4공영주차장 셔틀 또는 택시 이동을 계산합니다.'],
  ['한옥 숙박', '숙소 자체 주차 가능 여부를 먼저 확인하고, 불가하다면 숙소가 안내하는 제휴 주차장을 우선합니다.']
];

const fieldCheckpoints = [
  {
    title: '중심 골목은 오후보다 오전이 편합니다',
    body: '한복 대여점과 간식 가게가 몰린 길은 오후로 갈수록 멈춰 서는 시간이 늘어납니다. 사진과 경기전 관람을 먼저 끝내고, 간식은 이동 중간에 끊어 넣는 편이 동선이 덜 늘어집니다.'
  },
  {
    title: '오목대는 “갈까 말까”를 일찍 정합니다',
    body: '전망은 좋지만 오르막이 있어 부모님, 아이, 더운 날 일정에서는 피로가 빨리 쌓입니다. 경기전과 전동성당을 본 뒤 컨디션이 괜찮을 때만 올리고, 어렵다면 남부시장이나 카페 휴식으로 바꾸는 편이 낫습니다.'
  },
  {
    title: '남부시장은 식사 대안이 아니라 별도 일정입니다',
    body: '한옥마을 간식까지 먹은 뒤 남부시장 식사를 붙이면 양보다 대기와 이동이 부담이 됩니다. 점심을 남부시장으로 잡을지, 한옥마을 안에서 먹고 시장은 저녁 또는 야시장으로 볼지 먼저 나누면 좋습니다.'
  },
  {
    title: '주차는 10분 넘게 막히면 전환 기준이 필요합니다',
    body: '가까운 주차장을 계속 기다리면 관람, 식사, 카페 시간이 한꺼번에 밀립니다. 주말에는 제4공영주차장 셔틀이나 남부시장 권역 주차로 바꿀 기준을 미리 정해두는 편이 현실적입니다.'
  }
];

const fieldPhotos = [
  {
    src: '/images/jeonju-hanok-village/gyeonggijeon-main-gate.jpg',
    alt: '전주 경기전 정문과 그늘진 입구 풍경',
    width: 1800,
    height: 1013,
    caption: '경기전은 한옥마을 동선의 기준점입니다. 입구에서 관람 여부와 골목 방향을 먼저 정하면 이후 이동이 단순해집니다.'
  },
  {
    src: '/images/jeonju-hanok-village/jeondong-cathedral.jpg',
    alt: '파란 하늘 아래 전주 전동성당 외관',
    width: 1800,
    height: 1013,
    caption: '전동성당은 경기전과 붙여 보기 좋습니다. 내부 관람보다 외관 사진만 잡아도 코스의 만족도가 올라갑니다.'
  },
  {
    src: '/images/jeonju-hanok-village/quiet-hanok-alley.jpg',
    alt: '전주 한옥마을의 조용한 한옥 골목',
    width: 1600,
    height: 901,
    caption: '큰길에서 한 블록만 벗어나도 훨씬 조용한 골목이 나옵니다. 사진 중심 일정이라면 중심 상권만 고집하지 않는 편이 좋습니다.'
  },
  {
    src: '/images/jeonju-hanok-village/hanok-garden-pavilion.jpg',
    alt: '전주 한옥마을 정원 속 한옥 정자',
    width: 1600,
    height: 901,
    caption: '정자와 작은 정원은 더운 날 쉬어 가는 포인트가 됩니다. 짧은 코스라도 휴식 지점을 하나 넣어두면 체감 피로가 줄어듭니다.'
  },
  {
    src: '/images/jeonju-hanok-village/hanok-village-map-sign.jpg',
    alt: '전주 한옥마을 안내 지도 표지판',
    width: 1600,
    height: 901,
    caption: '초입의 안내 지도는 한 번 찍어두는 것이 좋습니다. 주차장, 경기전, 오목대, 남부시장 방향을 현장에서 다시 확인하기 쉽습니다.'
  },
  {
    src: '/images/jeonju-hanok-village/white-western-style-house.jpg',
    alt: '전주 한옥마을 하얀양옥집 입구',
    width: 1600,
    height: 901,
    caption: '하얀양옥집처럼 한옥 사이에 다른 결의 건축물이 섞여 있어, 산책 코스를 문화공간 위주로 잡아도 지루하지 않습니다.'
  }
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '전주 한옥마을은 몇 시간 정도 잡아야 하나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '대표 지점만 빠르게 보면 2시간도 가능하지만, 경기전 관람과 식사, 오목대 전망까지 넣으면 반나절이 안정적입니다.'
      }
    },
    {
      '@type': 'Question',
      name: '전주 한옥마을 주차는 어디가 좋나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '가까운 공영주차장은 편하지만 혼잡할 수 있습니다. 주말에는 제4공영주차장과 셔틀, 남부시장 연계 주차도 함께 검토하는 편이 좋습니다.'
      }
    }
  ]
};

const heroImage = getTourApiImage('jeonju', {
  src: '/images/domestic-places/jeonju-hanok-village-hero.jpg',
  alt: '전주 한옥마을 한옥 지붕과 골목 풍경',
  caption: '전주 한옥마을은 골목 산책, 문화유산, 먹거리 동선을 함께 봐야 만족도가 높습니다. 사진: Bernard Gagnon, Wikimedia Commons, CC0'
});
---
<BaseLayout title={`${article.title} - Tourpick360`} description={article.description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <article class="article-page longform">
    <nav class="breadcrumb" aria-label="현재 위치">
      <a href="/">홈</a>
      <span>/</span>
      <a href="/domestic/">국내여행</a>
      <span>/</span>
      <span>전주</span>
    </nav>

    <p class="eyebrow">전북 전주 여행</p>
    <h1>{article.title}</h1>
    <p class="lead">
      전주 한옥마을은 검색량과 방문 수요가 꾸준한 대표 국내 여행지입니다. 하지만 막상 가보면
      한복 대여, 길거리 음식, 경기전, 전동성당, 오목대, 남부시장까지 선택지가 많아 동선이 쉽게 흩어집니다.
      이 글은 처음 방문하는 여행자가 반나절 또는 1박 2일 일정으로 무리 없이 걷도록 주차, 시간대,
      숙소 위치, 식사 동선을 함께 정리합니다.
    </p>

    <figure class="article-hero-image">
      <img src={heroImage.src} alt={heroImage.alt} width="960" height="540" loading="eager" />
      <figcaption>{heroImage.caption}</figcaption>
    </figure>

    <h2>핵심 요약</h2>
    <table>
      <tbody>
        <tr><th>추천 대상</th><td>전주 첫 방문자, 가족 여행, 커플 여행, 부모님 동반 여행</td></tr>
        <tr><th>추천 시간</th><td>대표 코스 2시간, 여유 코스 반나절, 야경과 숙박까지 보면 1박 2일</td></tr>
        <tr><th>주요 동선</th><td>경기전, 전동성당, 태조로, 오목대, 전주향교, 남부시장</td></tr>
        <tr><th>주의사항</th><td>주말 오후에는 주차와 식사 대기, 한복 대여점 주변 혼잡이 커질 수 있습니다.</td></tr>
      </tbody>
    </table>

    <section>
      <h2>전주 한옥마을은 시간대 선택이 중요합니다</h2>
      <p>
        한옥마을은 연중무휴 24시간 개방되는 공간이지만, 여행 만족도는 방문 시간대에 따라 크게 달라집니다.
        오전에는 단체 관광객이 몰리기 전 경기전과 전동성당 주변을 차분하게 볼 수 있고, 오후에는 한복 대여와
        길거리 음식 수요가 늘어 중심 골목이 붐빕니다. 사진을 목적으로 한다면 오전 늦게 경기전 돌담길을 보고,
        해 질 무렵 오목대나 경기전 담장길 야경으로 마무리하는 흐름이 좋습니다.
      </p>
    </section>

    <section>
      <h2>현장에서 바로 갈리는 체크 포인트</h2>
      <p>
        한옥마을은 지도에서 보면 모든 지점이 가까워 보이지만, 실제로는 골목 혼잡도와 식사 대기,
        오목대 오르막, 주차장 진입 대기 때문에 체감 시간이 달라집니다. 방문 전에는 명소를 많이 넣기보다
        “어디서 멈추고 어디를 포기할지”를 정해두면 일정이 훨씬 편해집니다.
      </p>
      <div class="route-notes">
        {fieldCheckpoints.map((checkpoint) => (
          <section>
            <h3>{checkpoint.title}</h3>
            <p>{checkpoint.body}</p>
          </section>
        ))}
      </div>
    </section>

    <section>
      <h2>2026년 6월 현장 사진으로 본 동선</h2>
      <p>
