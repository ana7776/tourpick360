      <p>
        전주 한옥마을은 중심부에 가까운 주차장이 편하지만, 그만큼 주말과 성수기에는 진입 대기 시간이 길어질 수 있습니다.
        공식 안내 기준으로 제1·2·3공영주차장은 기본 30분 1,200원, 추가 15분 600원, 1일 최대 14,400원입니다.
        반면 제4공영주차장은 무료이고 주차면수가 많지만 한옥마을 중심부까지 셔틀 또는 추가 이동이 필요합니다.
        남부시장까지 함께 볼 계획이라면 한옥마을 바로 앞 주차장보다 남부시장 쪽 주차장이 더 자연스러울 때도 있습니다.
      </p>
      {naverMapNcpKeyId && (
        <div class="parking-map-panel">
          <div>
            <p class="eyebrow">Naver Maps API</p>
            <h3>전주 한옥마을 주차장 지도</h3>
            <p>주소를 네이버 지도 API로 좌표 변환해 주차장 위치를 한 화면에 표시합니다.</p>
          </div>
          <div id="jeonju-parking-map" class="parking-map" aria-label="전주 한옥마을 주차장 네이버 지도"></div>
          <p id="jeonju-parking-map-status" class="parking-map-status">네이버 지도 정보를 불러오는 중입니다.</p>
        </div>
      )}
      <table>
        <thead>
          <tr><th>주차장</th><th>면수·위치</th><th>요금</th><th>이럴 때 유리</th></tr>
        </thead>
        <tbody>
          {parkingMapRows.map((parking) => (
            <tr>
              <td>
                <strong>{parking.name}</strong>
                <a class="map-link" href={parking.mapUrl} target="_blank" rel="noopener noreferrer">네이버지도</a>
                <br />{parking.caution}
              </td>
              <td>{parking.spaces}<br />{parking.address}</td>
              <td>{parking.fee}</td>
              <td>{parking.bestFor}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p>
        한옥마을 제4공영주차장 셔틀버스는 전주시 공식 안내 기준 연중무휴 무료로 운영됩니다.
        운행 구간은 제4공영주차장, 자만벽화마을 경유, 태조로 승강장, 제4공영주차장 순서입니다.
        평일은 제4공영주차장 기준 10:20부터 18:30까지 정해진 시간표 중심으로 운행하고,
        토·일요일과 공휴일은 10:00~18:30 사이 수시 운행으로 안내되어 있습니다.
        다만 셔틀은 승용차 이용 고객 대상 무료 운행이므로, 늦은 저녁 야경이나 남부시장 야시장까지 보는 일정이라면 복귀 교통을 따로 계산해야 합니다.
      </p>
    </section>

    {naverMapNcpKeyId && (
      <>
        <script is:inline src={`https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=${naverMapNcpKeyId}&submodules=geocoder`}></script>
        <script type="application/json" id="jeonju-parking-map-data" set:html={JSON.stringify(parkingMapData)} />
        <script is:inline>
          (() => {
            const statusEl = document.getElementById('jeonju-parking-map-status');
            const mapEl = document.getElementById('jeonju-parking-map');
            const dataEl = document.getElementById('jeonju-parking-map-data');

            if (!statusEl || !mapEl || !dataEl) return;

            const setStatus = (message) => {
              statusEl.textContent = message;
            };

            const renderMap = () => {
              if (!window.naver?.maps?.Service) {
                setStatus('네이버 지도 API를 불러오지 못했습니다. 지도 버튼으로 위치를 확인해 주세요.');
                return;
              }

              const parkingRows = JSON.parse(dataEl.textContent || '[]');
              const map = new naver.maps.Map(mapEl, {
                center: new naver.maps.LatLng(35.815, 127.153),
                zoom: 14
              });
              const bounds = new naver.maps.LatLngBounds();
              const infoWindow = new naver.maps.InfoWindow({ borderWidth: 0 });
              let completed = 0;
              let markerCount = 0;

              parkingRows.forEach((parking) => {
                naver.maps.Service.geocode({ address: parking.searchAddress }, (status, response) => {
                  completed += 1;
                  const result = response?.v2?.addresses?.[0];

                  if (status === naver.maps.Service.Status.OK && result) {
                    const position = new naver.maps.LatLng(Number(result.y), Number(result.x));
                    const marker = new naver.maps.Marker({
                      map,
                      position,
                      title: parking.name
                    });

                    naver.maps.Event.addListener(marker, 'click', () => {
                      infoWindow.setContent(
                        `<div class="parking-info-window"><strong>${parking.name}</strong><span>${parking.address}</span><a href="${parking.mapUrl}" target="_blank" rel="noopener noreferrer">네이버지도에서 보기</a></div>`
                      );
                      infoWindow.open(map, marker);
                    });

                    bounds.extend(position);
                    markerCount += 1;
                  }

                  if (completed === parkingRows.length) {
                    if (markerCount > 1) {
                      map.fitBounds(bounds);
                      setStatus(`${markerCount}개 주차장 위치를 지도에 표시했습니다.`);
                    } else if (markerCount === 1) {
                      setStatus('1개 주차장 위치를 지도에 표시했습니다. 나머지는 네이버지도 버튼으로 확인해 주세요.');
                    } else {
                      setStatus('좌표 변환 결과가 없습니다. 네이버지도 버튼으로 위치를 확인해 주세요.');
                    }
                  }
                });
              });
            };

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', renderMap, { once: true });
            } else {
              renderMap();
            }
          })();
        </script>
      </>
    )}

    <section>
