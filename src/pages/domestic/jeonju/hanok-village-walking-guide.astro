---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { naverMapSearchUrl } from '../../../utils/naverMapLinks.js';
import { getTourApiImage } from '../../../data/tourApiImages.js';

const article = {
  title: '전주 한옥마을 여행 코스와 주차 동선 가이드',
  description: '전주 한옥마을을 처음 방문하는 여행자를 위해 경기전, 전동성당, 오목대, 남부시장 동선과 주차, 시간대, 숙소 위치 기준을 정리합니다.'
};

const routePlans = [
  ['2시간 산책', '경기전 돌담길 → 전동성당 외관 → 태조로 골목 → 오목대 전망대'],
  ['반나절 코스', '경기전 → 전동성당 → 한복 대여 또는 공방 체험 → 오목대 → 남부시장'],
  ['1박 2일', '첫날 한옥마을 중심부와 야경, 둘째 날 전주향교와 남부시장 또는 객리단길']
];

