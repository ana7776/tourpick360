---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { naverMapSearchUrl } from '../../../utils/naverMapLinks.js';

const courseRows = [
  {
    section: '나로도항 도착·매표 확인',
    time: '10~20분',
    difficulty: '쉬움',
    point: '예매 내역, 신분증, 승선 위치를 먼저 확인합니다. 주말과 꽃이 좋은 계절에는 대기 시간이 늘 수 있습니다.'
  },
  {
    section: '쑥섬 선착장·마을 입구',
    time: '5~10분',
    difficulty: '쉬움',
    point: '배에서 내려 전체 동선을 파악하는 구간입니다. 돌아오는 배 시간을 이때 한 번 더 확인하면 좋습니다.'
  },
  {
    section: '마을길·정원 진입 구간',
    time: '15~25분',
    difficulty: '보통',
    point: '짧지만 오르막과 계단이 섞입니다. 부모님 동반이면 이 구간에서 속도를 무리하지 않는 편이 좋습니다.'
  },
  {
    section: '정원·수국길·사진 포인트',
    time: '30~50분',
    difficulty: '보통',
    point: '쑥섬의 체류 시간이 가장 길어지는 구간입니다. 햇빛이 강한 날은 물과 모자가 만족도를 크게 좌우합니다.'
  },
  {
    section: '숲길·바다 전망 구간',
    time: '30~45분',
    difficulty: '보통~약간 어려움',
    point: '그늘이 있어 걷기 좋지만 흙길과 경사가 있습니다. 비 온 뒤에는 미끄럼과 신발 상태를 봐야 합니다.'
  },
  {
    section: '마을 복귀·선착장 대기',
    time: '15~25분',
    difficulty: '보통',
    point: '사진을 더 찍고 싶어도 배 시간 20~30분 전에는 선착장 방향으로 내려오는 편이 안전합니다.'
  }
];

const planTypes = [
  ['가볍게 보는 코스', '섬 안 정원과 마을길 중심', '약 1시간 30분~2시간', '걷는 데 부담이 있거나 부모님과 함께라면 추천'],
  ['사진 중심 코스', '정원, 수국길, 전망 포인트를 천천히', '약 2~3시간', '꽃 상태와 빛이 좋은 날 체류 시간이 길어집니다.'],
  ['섬 한 바퀴 코스', '정원, 숲길, 바다 전망 구간까지 연결', '약 2시간 30분~3시간 30분', '운동화와 여유 배편 확인이 필요합니다.']
];

const nearbyPlaces = [
  {
    name: '나로도항',
    angle: '배를 타기 전후로 식사와 대기 시간을 조절하기 좋은 출발점입니다.',
    tip: '쑥섬 일정은 나로도항의 주차와 승선 시간을 기준으로 역산하면 실패가 줄어듭니다.'
  },
  {
    name: '나로우주센터 우주과학관',
    angle: '아이와 함께라면 섬 산책 뒤 실내 관람을 붙이기 좋습니다.',
    tip: '운영일과 관람 시간을 확인하고, 섬 일정이 늦어지면 다음 일정으로 넘기는 편이 낫습니다.'
  },
  {
    name: '고흥우주발사전망대·남열해돋이해수욕장',
    angle: '바다 전망과 드라이브를 함께 넣고 싶을 때 어울립니다.',
    tip: '일몰이나 해안 풍경을 보는 일정이면 쑥섬에서 체력을 너무 쓰지 않도록 조절합니다.'
  },
  {
    name: '녹동항·소록도 권역',
    angle: '고흥을 하루 더 볼 계획이라면 숙박, 식사, 다음 이동 동선과 연결하기 좋습니다.',
    tip: '쑥섬 당일치기와 함께 무리하게 넣기보다는 1박 일정에서 검토하는 편이 현실적입니다.'
  }
];

const foodRoutes = [
  {
    timing: '승선 전',
    area: '나로도항 주변',
    search: '나로도항 맛집',
    fit: '아침을 못 먹었거나 배 타기 전 대기 시간이 40분 이상 남았을 때',
    note: '배 시간이 정해져 있으니 주문과 식사 시간이 짧은 메뉴가 편합니다.'
  },
  {
    timing: '쑥섬 복귀 직후',
    area: '나로도항·봉래면 식당권',
    search: '고흥 봉래면 식당',
    fit: '섬 안을 2시간 이상 걷고 점심을 먹는 일정',
    note: '섬 산책 뒤에는 멀리 이동하기보다 항구 가까운 곳에서 쉬는 편이 피로가 적습니다.'
  },
  {
    timing: '우주과학관 연계',
    area: '나로우주센터 주변',
    search: '나로우주센터 주변 맛집',
    fit: '아이 동반 또는 실내 관람을 오후 일정으로 붙일 때',
    note: '관람 시간과 식당 브레이크 타임이 겹칠 수 있어 이동 전에 영업 여부를 확인합니다.'
  },
  {
    timing: '해안 드라이브 후',
    area: '남열해돋이해수욕장·우주발사전망대 권역',
    search: '남열해돋이해수욕장 맛집',
    fit: '바다 전망과 일몰 방향으로 오후 일정을 잡을 때',
    note: '해안권 식당은 계절과 요일에 따라 영업 편차가 있으니 지도에서 최신 리뷰와 영업 시간을 봅니다.'
  },
  {
    timing: '1박 일정 저녁',
    area: '녹동항 권역',
    search: '녹동항 맛집',
    fit: '고흥에서 숙박하거나 다음 날 소록도·거금도 방향으로 움직일 때',
    note: '당일치기라면 무리하게 넣지 말고, 숙박 동선일 때 저녁 식사권으로 잡는 것이 좋습니다.'
  }
];
---
<BaseLayout title="고흥 쑥섬 도보 코스와 난이도, 주변 관광 가이드 - Tourpick360" description="고흥 쑥섬 여행에서 나로도항 배편, 섬 안 정원과 숲길 도보 코스, 구간별 소요 시간, 난이도, 주변 관광지 연결 방법을 정리합니다.">
  <article class="article-page longform">
    <nav class="breadcrumb" aria-label="현재 위치">
      <a href="/">홈</a><span>/</span><a href="/domestic/">국내여행</a><span>/</span><span>고흥</span>
    </nav>
    <p class="eyebrow">고흥 섬 도보여행</p>
    <h1>고흥 쑥섬 도보 코스와 난이도, 주변 관광 가이드</h1>
    <p class="lead">고흥 쑥섬은 작게 보이지만 배편, 오르막, 정원 체류 시간, 돌아오는 배 시간이 함께 맞아야 만족도가 높습니다. 단순히 주소만 보고 가기보다 나로도항 출발부터 섬 안 걷는 구간, 주변 관광지까지 하루 흐름으로 보는 편이 좋습니다.</p>

    <figure class="article-hero-image">
      <img src="/images/goheung-ssookseom/ssookseom-flower-sea-view.jpg" alt="고흥 쑥섬 정원에서 내려다본 꽃길과 바다 전망" width="1800" height="1013" />
      <figcaption>쑥섬 정원에서는 꽃길과 나로도 바다 전망을 함께 볼 수 있습니다.</figcaption>
    </figure>

    <section class="checklist-box">
      <h2>먼저 보는 핵심 요약</h2>
      <ul>
        <li>출발 기준점은 전남 고흥 나로도항입니다.</li>
        <li>쑥섬 공식 안내 기준 선비와 입장료가 별도로 안내되어 있으므로 방문 전 금액을 다시 확인해야 합니다.</li>
        <li>주말, 공휴일, 꽃이 좋은 6~7월 전후에는 배편이 빠르게 마감될 수 있어 사전 예매가 유리합니다.</li>
        <li>섬 안은 짧은 평지 산책만 있는 곳이 아니라 오르막, 계단, 흙길이 섞입니다.</li>
        <li>사진을 많이 찍는다면 섬 체류 시간을 최소 2시간 이상으로 잡는 편이 편합니다.</li>
      </ul>
    </section>

    <h2>쑥섬 여행의 핵심은 배 시간 역산입니다</h2>
    <p>쑥섬은 고흥 나로도항에서 배로 들어가는 섬 여행지입니다. 공식 홈페이지는 선비, 입장료, 예약 안내와 함께 주말·공휴일 및 6~7월에는 매진 가능성이 있다고 안내합니다. 그래서 여행 당일에는 "몇 시 배를 탈까"보다 "섬에서 얼마 동안 걷고 몇 시 배로 돌아올까"를 먼저 정하는 편이 좋습니다.</p>
    <p>특히 부모님, 아이, 사진 촬영을 좋아하는 동행이 있다면 실제 체류 시간이 늘어납니다. 섬이 작아 보여도 정원에서 멈추고, 전망 구간에서 쉬고, 선착장으로 다시 내려오는 시간을 더하면 일정이 빠듯해질 수 있습니다.</p>

    <div class="article-photo-grid">
      <figure>
        <img src="/images/goheung-ssookseom/ssookseom-village-garden.jpg" alt="고흥 쑥섬 마을과 정원으로 이어지는 입구 풍경" width="1600" height="901" loading="lazy" />
        <figcaption>선착장 이후 마을길과 정원 구간으로 이어집니다.</figcaption>
      </figure>
      <figure>
        <img src="/images/goheung-ssookseom/ssookseom-harbor-view.jpg" alt="쑥섬 전망 구간에서 바라본 나로도항과 바다" width="1600" height="901" loading="lazy" />
        <figcaption>전망 구간은 사진 체류 시간이 길어지기 쉽습니다.</figcaption>
      </figure>
    </div>

    <h2>구간별 도보 시간과 난이도</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>구간</th>
            <th>예상 시간</th>
            <th>난이도</th>
            <th>체크 포인트</th>
          </tr>
        </thead>
        <tbody>
          {courseRows.map((row) => (
            <tr>
              <td>{row.section}</td>
              <td>{row.time}</td>
              <td>{row.difficulty}</td>
              <td>{row.point}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2>일정 유형별 추천 코스</h2>
    <p>쑥섬은 모든 구간을 다 걷는 것보다 동행자의 체력과 배 시간에 맞춰 범위를 정하는 것이 좋습니다. 아래 시간은 사진 촬영, 휴식, 대기 시간을 포함한 여유 기준입니다.</p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>코스 유형</th>
            <th>동선</th>
            <th>권장 체류 시간</th>
            <th>추천 상황</th>
          </tr>
        </thead>
        <tbody>
          {planTypes.map(([type, route, time, tip]) => (
            <tr>
              <td>{type}</td>
              <td>{route}</td>
              <td>{time}</td>
              <td>{tip}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2>초보자와 부모님 동반은 이렇게 조정합니다</h2>
    <p>걷는 데 익숙하지 않은 동행이 있다면 숲길까지 욕심내기보다 정원과 전망이 좋은 지점 중심으로 잡는 편이 좋습니다. 오르막을 오른 뒤에는 바로 다음 포인트로 이동하지 말고 그늘이나 벤치가 보일 때 쉬어야 전체 피로가 줄어듭니다.</p>
    <p>신발은 샌들보다 운동화가 낫습니다. 섬 안에는 포장길만 이어지는 것이 아니고, 비가 온 뒤에는 흙길과 계단이 미끄러울 수 있습니다. 여름에는 양산보다 모자와 물이 더 실용적이고, 사진 촬영이 길어질수록 햇빛 노출 시간이 길어집니다.</p>

    <figure class="article-inline-photo">
      <img src="/images/goheung-ssookseom/ssookseom-hydrangea-walk.jpg" alt="고흥 쑥섬 수국길과 오르막 산책로" width="1600" height="901" loading="lazy" />
      <figcaption>꽃길 구간도 오르막과 계단이 섞여 있어 신발과 속도 조절이 중요합니다.</figcaption>
    </figure>

    <h2>하루 일정 예시</h2>
    <ol>
      <li>오전: 나로도항 도착, 주차, 승선권과 신분증 확인</li>
      <li>오전~점심 전: 쑥섬 이동 후 마을길, 정원, 전망 구간 산책</li>
      <li>점심: 나로도항 복귀 후 식사 또는 카페 휴식</li>
      <li>오후: 나로우주센터 우주과학관이나 해안 전망 코스 중 하나만 선택</li>
      <li>저녁 전: 숙소 권역 또는 다음 이동지로 이동</li>
    </ol>
    <p>쑥섬을 오전에 넣는 이유는 단순합니다. 배편 변수가 있는 여행지는 앞 일정으로 배치해야 뒤 일정이 덜 흔들립니다. 오후에 섬을 넣으면 매진, 기상, 체력 변수 때문에 주변 관광까지 같이 무너질 수 있습니다.</p>

    <h2>주변에 함께 볼 만한 곳</h2>
    <div class="guide-list">
      {nearbyPlaces.map((place) => (
        <article>
          <h3>{place.name}</h3>
          <p>{place.angle}</p>
          <small>{place.tip}</small>
        </article>
      ))}
    </div>

    <div class="article-photo-grid">
      <figure>
        <img src="/images/goheung-ssookseom/ssookseom-garden-trail.jpg" alt="고흥 쑥섬 정원의 돌길과 바다를 향한 산책로" width="1600" height="901" loading="lazy" />
        <figcaption>정원길은 천천히 걷고 사진을 찍기 좋은 핵심 구간입니다.</figcaption>
      </figure>
      <figure>
        <img src="/images/goheung-ssookseom/ssookseom-nature-sign.jpg" alt="고흥 쑥섬 나태릿시런 숲길 안내판" width="1400" height="788" loading="lazy" />
        <figcaption>현장 안내판을 보며 숲길 범위를 조절하면 무리한 동선을 줄일 수 있습니다.</figcaption>
      </figure>
    </div>

    <h2>맛집과 음식점 동선 잡는 법</h2>
    <p>쑥섬 여행에서 음식점은 이름보다 위치와 타이밍이 먼저입니다. 배 시간이 있는 날에는 줄 서는 맛집을 먼저 고르기보다, 나로도항 복귀 시간과 다음 관광지 방향에 맞춰 식사권을 정하는 편이 안전합니다.</p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>식사 타이밍</th>
            <th>추천 권역</th>
            <th>맞는 상황</th>
            <th>체크 포인트</th>
            <th>지도 검색</th>
          </tr>
        </thead>
        <tbody>
          {foodRoutes.map((route) => (
            <tr>
              <td>{route.timing}</td>
              <td>{route.area}</td>
              <td>{route.fit}</td>
              <td>{route.note}</td>
              <td>
                <a class="map-link" href={naverMapSearchUrl({ name: route.search, region: '고흥' })} target="_blank" rel="noopener noreferrer">
                  네이버지도
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p>개별 음식점은 영업일, 재료 소진, 브레이크 타임, 리뷰 상태가 자주 바뀝니다. 그래서 이 글에서는 특정 상호를 고정 추천하기보다 권역별 검색 링크를 두고, 방문 당일 네이버지도에서 영업 중 여부와 최근 리뷰를 확인하도록 구성했습니다.</p>

    <h2>예약 전 체크리스트</h2>
    <ul>
      <li>쑥섬 배편 예약 가능 여부와 돌아오는 배 시간</li>
      <li>신분증 지참 여부</li>
      <li>나로도항 주차와 매표 위치</li>
      <li>섬 안 도보 구간을 걸을 수 있는 신발</li>
      <li>물, 모자, 우천 시 미끄럼 대비</li>
      <li>주변 관광지는 하나만 고를지, 1박 일정으로 나눌지</li>
      <li>식사 권역은 나로도항 복귀 시간과 다음 관광지 방향에 맞는지</li>
    </ul>

