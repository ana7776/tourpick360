{
  "name": "tourpick360",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1",
    "check:seo": "astro build && node scripts/check-seo-build.mjs",
    "images:r2": "node scripts/r2-image-pipeline.mjs",
    "tourapi:images": "node scripts/fetch-tourapi-images.mjs",
    "cf:login": "wrangler login",
    "cf:create": "wrangler pages project create tourpick360 --production-branch=main",
    "cf:deploy": "npm run build && wrangler pages deploy dist --project-name=tourpick360 --branch=main"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.716.0",
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^6.4.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "wrangler": "^4.98.0"
  }
}
